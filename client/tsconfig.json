{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": ["../tsconfig.base.json"],
  "compilerOptions": {
    "lib": ["DOM", "ESNext"],
    "types": ["svelte", "vite/client"],
    "paths": {
      "@/shared/*": ["../shared/*"],
      "@/sdk.ts": ["./src/sdk/sdk-manager.ts"],
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.js",
    "./**/*.svelte",
    "../shared/",
    "./atlas-builder/**/*.ts",
    "./building-editor/**/*.ts",
    "vite.config.ts",
    "./global.d.ts"
  ]
}
